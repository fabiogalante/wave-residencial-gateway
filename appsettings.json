{
  "AllowedOrigins": [
    "https://wave-residencial-front.up.railway.app",
    "https://wave-residencial-portal.up.railway.app",
    "https://moradores.waveresidencialpg.com.br",
    "http://localhost:5173",
    "http://localhost:4173"
  ],
  "ReverseProxy": {
    "Routes": {
      "api-route": {
        "ClusterId": "api-cluster",
        "Match": {
          "Path": "/api/{**catch-all}"
        },
        "RateLimiterPolicy": "default",
        "Timeout": "00:00:30"
      },
      "auth-route": {
        "ClusterId": "api-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        },
        "RateLimiterPolicy": "auth",
        "Timeout": "00:00:30"
      }
    },
    "Clusters": {
      "api-cluster": {
        "Destinations": {
          "api": {
            "Address": "http://waveresidencialapi.railway.internal:8080"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Warning"
    }
  },
  "AllowedHosts": "*"
}
